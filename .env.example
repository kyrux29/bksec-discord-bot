SERVER_ID=1000000000000000600
BOT_TOKEN=replace-with-discord-bot-token
VIEW_ALL_CTF_ROLEID=1000000000000000601
ACTIVE_CTF_ROLEID=1000000000000000602
# ACTIVE_CTF_ROLEID: role required to view a CTF while it is running
# Use a different VIEW_ALL_CTF_ROLEID to preserve live/post-event visibility phases
LOG_CHANNELID=1000000000000000603

DENY_CTF_ROLEID=1000000000000000604

# Need A <<<VIEW_ALL_CTF>>> ROLE ID and ASSIGN that role to bot
# Need LOG CHANNEL ID if want to enable logging
# DENY_CTF_ROLEID: role that is explicitly denied ViewChannel on all CTF categories
# If it matches ACTIVE_CTF_ROLEID or VIEW_ALL_CTF_ROLEID, the bot disables it safely

ADMIN_ROLE_ID=1000000000000000605

# Optional: /verifyg10 is registered only when all three values are set
VERIFY_REMOVE_ROLE_ID=
VERIFY_GRANT_ROLE_ID=
VERIFY_ALLOWED_ROLE_ID=

# Task commands are currently disabled; these are only needed when re-enabled
TASK_ADMIN_CHANNEL_ID=1000000000000000606
TASK_ROLE_PWN=1000000000000000607
TASK_ROLE_REV=1000000000000000608
TASK_ROLE_CRYPTO=1000000000000000609
TASK_ROLE_ALL=1000000000000000610

# ADMIN_ROLE_ID: role allowed to manage CTF registration and admin commands
# TASK_ADMIN_CHANNEL_ID: channel receiving submission notifications
# TASK_ROLE_*: roles mentioned for each task category
